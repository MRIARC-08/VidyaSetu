AI_ENVIRONMENT="development"
AI_INTERNAL_API_KEY="replace-with-at-least-32-characters"
AI_LOG_LEVEL="INFO"

# The AI service will share PostgreSQL with the Next.js application. Vector
# tables will be introduced through a dedicated migration.
AI_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vidyasetu"

# Optional platform fallback. A user-owned key may be supplied by the trusted
# Next.js backend for a single request after the BYOK flow is implemented.
AI_GROQ_API_KEY=""
AI_GROQ_MODEL=""

AI_EMBEDDING_MODEL="intfloat/multilingual-e5-base"
AI_MODEL_CACHE_DIR=".cache/models"
AI_REQUEST_TIMEOUT_SECONDS=30
